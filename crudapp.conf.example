# CrudApp Configuration File
#
# Copy this file to crudapp.conf and customize for your environment.
#
# Configuration can also be set via environment variables:
#   CRUDAPP_DB_TYPE, CRUDAPP_DB_PATH, CRUDAPP_PORT, etc.
# Environment variables take precedence over config file settings.

[database]
# Database type: sqlite (for local dev) or mysql (for production)
type = sqlite

# SQLite settings (when type = sqlite)
path = ./dev.db

# MySQL settings (when type = mysql)
# Uncomment and fill in for production:
# type = mysql
# name = your_database
# user = your_username
# pass = your_password
# host = localhost

[server]
# Development server settings (used by dev/runner.pl)
port = 3000
host = 127.0.0.1
static_dir = ./example
# Base URL shown in emails (e.g. verification links)
# app_url = https://example.com

[smtp]
# SMTP settings for outgoing email (used by CrudApp::Email)
# Leave commented out to disable email sending.
#
# For STARTTLS (port 587, e.g. Gmail, SendGrid, Mailgun):
# host      = smtp.example.com
# port      = 587
# user      = noreply@example.com
# pass      = yourpassword
# from      = noreply@example.com
# from_name = My App
# starttls  = 1
#
# For SMTPS / direct TLS (port 465):
# ssl       = 1
#
# For a local relay with no auth (port 25):
# host      = localhost
# port      = 25
# from      = noreply@localhost
